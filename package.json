{
    "name": "roma-react",
    "version": "9.0.0",
    "homepage": "/start",
    "private": true,
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fullcalendar/core": "^6.1.4",
        "@fullcalendar/daygrid": "^6.1.4",
        "@fullcalendar/interaction": "^6.1.4",
        "@fullcalendar/react": "^6.1.4",
        "@fullcalendar/timegrid": "^6.1.4",
        "@mui/icons-material": "^7.3.8",
        "@mui/material": "^7.3.8",
        "@reduxjs/toolkit": "^1.9.5",
        "axios": "^1.3.4",
        "buffer": "^6.0.3",
        "chart.js": "4.2.1",
        "dotenv-webpack": "^8.0.1",
        "i18next": "^22.5.0",
        "prettier": "2.8.4",
        "primeflex": "^3.3.0",
        "primeicons": "^6.0.1",
        "primereact": "^9.2.0",
        "query-string": "^8.1.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-google-recaptcha": "^3.1.0",
        "react-helmet": "^6.1.0",
        "react-i18next": "^12.3.1",
        "react-redux": "^8.0.5",
        "react-router-dom": "^7.13.1",
        "react-scripts": "5.0.1",
        "sass": "^1.58.3",
        "web-vitals": "^3.1.1"
    },
    "scripts": {
        "start": "node scripts/set-env.mjs env.test.local && vite --host --port 8351",
        "dev": "node scripts/set-env.mjs env.dev.local && vite --host --port 8351",
        "devBrztest": "node scripts/set-env.mjs env.brztest && vite --host --port 8351",
        "local": "node scripts/set-env.mjs env.local.local && vite --host --port 8351",
        "bdev": "node scripts/set-env.mjs env.bdev.local && vite --host --port 8351",
        "sdev": "node scripts/set-env.mjs env.sdev.local && vite --host --port 8351",
        "devTic": "node scripts/set-env.mjs env.devTic.local && vite --host --port 8351",
        "devTicT": "node scripts/set-env.mjs env.devTicT.local && vite --host --port 8351",
        "boban": "node scripts/set-env.mjs env.boban.local && vite --host --port 8351",
        "prod": "node scripts/set-env.mjs env.prod.local && vite --host --port 8351",
        "build": "node scripts/set-env.mjs env.devTic.local && vite build",
        "buildDev": "node scripts/set-env.mjs env.dev.local && vite build",
        "buildLocal": "node scripts/set-env.mjs env.local.local && vite build",
        "buildDevTic": "node scripts/set-env.mjs env.devTic.local && vite build",
        "preview": "vite preview --host --port 8351",
        "previewDev": "node scripts/set-env.mjs env.dev.local && vite build && vite preview --host --port 8351",
        "previewDevTic": "node scripts/set-env.mjs env.devTic.local && vite build && vite preview --host --port 8351",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "format": "prettier --write \"src/**/*.{js,ts,tsx}\""
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^5.1.0",
        "vite": "^7.1.7"
    }
}
